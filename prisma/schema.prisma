generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SECURITY
  WARGA
}

enum PackageStatus {
  RECEIVED_BY_SECURITY
  DELIVERED_TO_WARGA
}

// --- MODEL USER YANG DIPERBARUI ---
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? // Dibutuhkan oleh NextAuth
  image         String?   // Dibutuhkan oleh NextAuth (untuk foto profil)
  password      String?   // Tambahan dari kita untuk login manual (email/password)
  
  role          Role      @default(WARGA)
  unitNumber    String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relasi NextAuth
  accounts      Account[]
  sessions      Session[]

  // Relasi Aplikasi Kita
  packages         Package[] @relation("WargaPackages")
  recordedPackages Package[] @relation("SecurityRecordedPackages")
}

// --- TABEL WAJIB NEXTAUTH ---
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- MODEL PACKAGE (TETAP SAMA) ---
model Package {
  id             String        @id @default(uuid())
  trackingNumber String?
  courierName    String
  recipientName  String
  unitNumber     String
  status         PackageStatus @default(RECEIVED_BY_SECURITY)
  
  receivedAt     DateTime      @default(now())
  pickedUpAt     DateTime?

  wargaId        String?
  warga          User?         @relation("WargaPackages", fields: [wargaId], references: [id])

  securityId     String
  security       User          @relation("SecurityRecordedPackages", fields: [securityId], references: [id])
}