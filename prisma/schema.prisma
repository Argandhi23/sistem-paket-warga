generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SECURITY
  WARGA
}

enum PackageStatus {
  RECEIVED_BY_SECURITY
  DELIVERED_TO_WARGA
}

// --- MODEL USER YANG DIPERBARUI ---
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? // Dibutuhkan oleh NextAuth
  image         String?   // Dibutuhkan oleh NextAuth (untuk foto profil)
  password      String?   // Tambahan dari kita untuk login manual (email/password)
  
  role          Role      @default(WARGA)
  unitNumber    String?
  
  // 🌟 TAMBAHAN BARU UNTUK TIKET JIRA: Relasi User ke Rumah
  rumahId       String?   // Foreign key penghubung ke tabel Rumah
  rumah         Rumah?    @relation(fields: [rumahId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relasi NextAuth
  accounts      Account[]
  sessions      Session[]

  // Relasi Aplikasi Kita
  packages         Package[] @relation("WargaPackages")
  recordedPackages Package[] @relation("SecurityRecordedPackages")
}

// 🌟 TABEL BARU UNTUK TIKET JIRA: RUMAH
model Rumah {
  id        String   @id @default(uuid())
  blok      String   // Contoh: "Blok A"
  nomor     String   // Contoh: "12"
  
  // Relasi: 1 Rumah bisa dihuni banyak User
  penghuni  User[]   
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- TABEL WAJIB NEXTAUTH ---
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- MODEL PACKAGE (TETAP SAMA) ---
model Package {
  id             String        @id @default(uuid())
  trackingNumber String?
  courierName    String
  recipientName  String
  unitNumber     String
  status         PackageStatus @default(RECEIVED_BY_SECURITY)
  
  receivedAt     DateTime      @default(now())
  pickedUpAt     DateTime?

  wargaId        String?
  warga          User?         @relation("WargaPackages", fields: [wargaId], references: [id])

  securityId     String
  security       User          @relation("SecurityRecordedPackages", fields: [securityId], references: [id])
}

// --- Tabel Warga ---
model Warga {
  id        String   @id @default(uuid())
  nama      String
  blokRumah String   // Contoh: "Blok A No. 12"
  noHp      String?  // Boleh kosong
  paket     Paket[]  // Relasi: 1 Warga bisa punya banyak Paket
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Status Paket ---
enum StatusPaket {
  PENDING   // Paket baru datang, belum diambil
  DIAMBIL   // Paket sudah diambil oleh warga
}

// --- Tabel Paket ---
model Paket {
  id             String      @id @default(uuid())
  resi           String?     // Nomor resi (boleh kosong kalau kurir tidak kasih resi)
  kurir          String      // Contoh: JNE, J&T, Shopee Express, Gojek
  status         StatusPaket @default(PENDING)
  
  // Relasi ke tabel Warga
  penerimaId     String
  penerima       Warga       @relation(fields: [penerimaId], references: [id], onDelete: Cascade)
  
  tanggalMasuk   DateTime    @default(now())
  tanggalDiambil DateTime?   // Akan diisi saat status berubah jadi DIAMBIL
}